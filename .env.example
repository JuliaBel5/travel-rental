# Neon Postgres connection strings.
# Get them from the Neon dashboard (or `vercel env pull .env` after adding the
# Neon integration in Vercel → Storage).

# Pooled connection (host contains "-pooler") — used by the app at runtime.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Unpooled / direct connection (no "-pooler") — used by `prisma migrate`.
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"
